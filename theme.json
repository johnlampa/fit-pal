{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"custom": true,
			"customDuotone": true,
			"customGradient": true,
			"link": true,
			"palette": [
				{
					"slug": "base",
					"name": "Base",
					"color": "#0f172a"
				},
				{
					"slug": "base-alt",
					"name": "Base Alt",
					"color": "#1e293b"
				},
				{
					"slug": "surface",
					"name": "Surface",
					"color": "#f8fafc"
				},
				{
					"slug": "surface-alt",
					"name": "Surface Alt",
					"color": "#e2e8f0"
				},
				{
					"slug": "contrast",
					"name": "Contrast",
					"color": "#f1f5f9"
				},
				{
					"slug": "contrast-muted",
					"name": "Contrast Muted",
					"color": "#94a3b8"
				},
				{
					"slug": "slate-500",
					"name": "Slate 500",
					"color": "#64748b"
				},
				{
					"slug": "slate-700",
					"name": "Slate 700",
					"color": "#334155"
				},
				{
					"slug": "accent",
					"name": "Accent",
					"color": "#22d3ee"
				},
				{
					"slug": "accent-strong",
					"name": "Accent Strong",
					"color": "#06b6d4"
				},
				{
					"slug": "success",
					"name": "Success",
					"color": "#34d399"
				},
				{
					"slug": "warning",
					"name": "Warning",
					"color": "#fbbf24"
				}
			],
			"gradients": [
				{
					"slug": "slate-depth",
					"name": "Slate Depth",
					"gradient": "linear-gradient(160deg, #0f172a 0%, #1e293b 55%, #334155 100%)"
				},
				{
					"slug": "light-surface",
					"name": "Light Surface",
					"gradient": "linear-gradient(180deg, #f8fafc 0%, #e2e8f0 100%)"
				},
				{
					"slug": "accent-glow",
					"name": "Accent Glow",
					"gradient": "linear-gradient(135deg, #06b6d4 0%, #22d3ee 50%, #34d399 100%)"
				}
			],
			"duotone": [
				{
					"slug": "slate-accent",
					"name": "Slate & Accent",
					"colors": ["#0f172a", "#22d3ee"]
				},
				{
					"slug": "slate-light",
					"name": "Slate & Light",
					"colors": ["#1e293b", "#f8fafc"]
				}
			]
		},
		"typography": {
			"customFontSize": true,
			"dropCap": false,
			"fluid": true,
			"fontStyle": true,
			"fontWeight": true,
			"letterSpacing": true,
			"lineHeight": true,
			"textDecoration": true,
			"textTransform": true,
			"writingMode": true,
			"fontFamilies": [
				{
					"fontFamily": "\"DM Sans\", ui-sans-serif, system-ui, sans-serif",
					"name": "DM Sans",
					"slug": "dm-sans"
				},
				{
					"fontFamily": "\"Outfit\", ui-sans-serif, system-ui, sans-serif",
					"name": "Outfit",
					"slug": "outfit"
				},
				{
					"fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
					"name": "Monospace",
					"slug": "monospace"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"name": "Small",
					"size": "0.875rem",
					"fluid": {
						"min": "0.8125rem",
						"max": "0.875rem"
					}
				},
				{
					"slug": "medium",
					"name": "Medium",
					"size": "1rem",
					"fluid": {
						"min": "0.9375rem",
						"max": "1rem"
					}
				},
				{
					"slug": "large",
					"name": "Large",
					"size": "1.25rem",
					"fluid": {
						"min": "1.125rem",
						"max": "1.25rem"
					}
				},
				{
					"slug": "x-large",
					"name": "Extra Large",
					"size": "1.75rem",
					"fluid": {
						"min": "1.375rem",
						"max": "1.75rem"
					}
				},
				{
					"slug": "xx-large",
					"name": "2X Large",
					"size": "2.5rem",
					"fluid": {
						"min": "1.875rem",
						"max": "2.5rem"
					}
				},
				{
					"slug": "huge",
					"name": "Huge",
					"size": "3.5rem",
					"fluid": {
						"min": "2.25rem",
						"max": "3.5rem"
					}
				}
			]
		},
		"spacing": {
			"blockGap": true,
			"margin": true,
			"padding": true,
			"customSpacingSize": true,
			"units": ["%", "px", "em", "rem", "vh", "vw"],
			"spacingScale": {
				"operator": "*",
				"increment": 1.5,
				"steps": 7,
				"mediumStep": 1.5,
				"unit": "rem"
			},
			"spacingSizes": [
				{
					"slug": "20",
					"name": "2X Small",
					"size": "0.5rem"
				},
				{
					"slug": "30",
					"name": "X Small",
					"size": "0.75rem"
				},
				{
					"slug": "40",
					"name": "Small",
					"size": "1rem"
				},
				{
					"slug": "50",
					"name": "Medium",
					"size": "1.5rem"
				},
				{
					"slug": "60",
					"name": "Large",
					"size": "2rem"
				},
				{
					"slug": "70",
					"name": "X Large",
					"size": "3rem"
				},
				{
					"slug": "80",
					"name": "2X Large",
					"size": "4.5rem"
				}
			]
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"defaultPresets": true
		},
		"dimensions": {
			"minHeight": true
		},
		"position": {
			"sticky": true
		},
		"blocks": {
			"core/button": {
				"border": {
					"radius": true
				},
				"color": {
					"background": true,
					"text": true
				},
				"spacing": {
					"padding": true,
					"margin": true
				}
			},
			"core/group": {
				"spacing": {
					"padding": true,
					"margin": true,
					"blockGap": true
				},
				"color": {
					"background": true,
					"text": true,
					"link": true
				},
				"border": {
					"color": true,
					"radius": true,
					"style": true,
					"width": true
				},
				"dimensions": {
					"minHeight": true
				}
			},
			"core/columns": {
				"spacing": {
					"padding": true,
					"margin": true,
					"blockGap": true
				}
			},
			"core/image": {
				"lightbox": {
					"enabled": true,
					"allowEditing": true
				}
			}
		},
		"custom": {
			"fitness": {
				"cta-radius": "4px",
				"section-gap": "4.5rem"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--dm-sans)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6",
			"fontWeight": "400"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--50)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--50)"
			},
			"blockGap": "1.5rem"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent-strong)"
					},
					"typography": {
						"textDecoration": "underline"
					}
				},
				":focus": {
					"outline": {
						"color": "var(--wp--preset--color--accent)",
						"offset": "2px",
						"style": "solid",
						"width": "2px"
					}
				},
				"typography": {
					"textDecoration": "none"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--outfit)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				},
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--huge)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "600"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "600",
					"textTransform": "uppercase",
					"letterSpacing": "0.06em"
				}
			},
			"button": {
				"border": {
					"radius": "4px"
				},
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--base)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--outfit)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "600",
					"lineHeight": "1.2"
				},
				"spacing": {
					"padding": {
						"top": "0.875rem",
						"right": "1.5rem",
						"bottom": "0.875rem",
						"left": "1.5rem"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--accent-strong)",
						"text": "var(--wp--preset--color--base)"
					}
				},
				":focus": {
					"outline": {
						"color": "var(--wp--preset--color--accent)",
						"offset": "2px",
						"style": "solid",
						"width": "2px"
					}
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--contrast-muted)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--outfit)",
					"fontWeight": "800",
					"fontSize": "var(--wp--preset--font-size--large)",
					"letterSpacing": "-0.02em"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--contrast)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent)"
							},
							"typography": {
								"textDecoration": "none"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--dm-sans)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "500"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--contrast-muted)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent)"
							},
							"typography": {
								"textDecoration": "none"
							}
						}
					}
				}
			},
			"core/separator": {
				"color": {
					"background": "var(--wp--preset--color--slate-700)"
				}
			},
			"core/quote": {
				"border": {
					"color": "var(--wp--preset--color--accent)",
					"width": "0 0 0 4px",
					"style": "solid"
				},
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--50)"
					}
				},
				"typography": {
					"fontStyle": "italic"
				}
			},
			"core/code": {
				"color": {
					"background": "var(--wp--preset--color--base-alt)",
					"text": "var(--wp--preset--color--accent)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--monospace)",
					"fontSize": "var(--wp--preset--font-size--small)"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--40)",
						"right": "var(--wp--preset--spacing--40)",
						"bottom": "var(--wp--preset--spacing--40)",
						"left": "var(--wp--preset--spacing--40)"
					}
				},
				"border": {
					"radius": "4px"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--outfit)",
					"fontWeight": "700"
				}
			},
			"core/button": {
				"variations": {
					"outline": {
						"border": {
							"color": "var(--wp--preset--color--accent)",
							"width": "2px",
							"style": "solid"
						},
						"color": {
							"background": "transparent",
							"text": "var(--wp--preset--color--accent)"
						}
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		},
		{
			"name": "ghl-lead-capture",
			"title": "GHL Lead Capture",
			"area": "uncategorized"
		}
	],
	"customTemplates": [
		{
			"name": "page-meal-planner",
			"title": "Meal Planner Dashboard",
			"postTypes": ["page"]
		}
	]
}
